# Server
NODE_ENV=development
PORT=4000

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/dineflow

# Clerk (Backend API Keys)
# Get from Clerk Dashboard -> API Keys
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# Optional (useful if you ever use redirect-based auth flows on backend)
CLERK_SIGN_IN_URL=/sign-in
CLERK_SIGN_UP_URL=/sign-up

# Stripe (Payments)
STRIPE_SECRET_KEY=sk_test_...
# Optional, needed if you add webhooks later
STRIPE_WEBHOOK_SECRET=whsec_...
FRONTEND_URL=http://localhost:5173

